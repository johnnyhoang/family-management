{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "server/api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/server/api/index.ts"
    },
    {
      "source": "/((?!api/v1|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
